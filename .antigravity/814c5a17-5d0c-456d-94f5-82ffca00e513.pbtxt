        }
        lines {
          text: "    id: \'raymarching-sphere\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Raymarched Metallic Sphere\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Simple 3D Raymarching with Diffuse, Specular, and Shadow rendering.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
