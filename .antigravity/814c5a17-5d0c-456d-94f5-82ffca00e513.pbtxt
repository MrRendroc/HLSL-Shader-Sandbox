        }
        lines {
          text: "        map(p + eps.xyy, dummyMat) - d,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        map(p + eps.yxy, dummyMat) - d,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        map(p + eps.yyx, dummyMat) - d"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Calculate shadow factor from point p towards light direction ld"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float getShadow(float3 p, float3 ld) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float shadow = 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float t = 0.02; // Min step"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    int dummyMat;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (int i = 0; i < 30; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float h = map(p + ld * t, dummyMat);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (h < 0.001) return 0.1; // In shadow"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        shadow = min(shadow, 16.0 * h / t); // Penumbra"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        t += h;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (t > 4.0) break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return saturate(shadow);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float4 mainImage(float2 fragCoord) : SV_Target {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
