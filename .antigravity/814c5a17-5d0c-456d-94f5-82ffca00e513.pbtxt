        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float4 mainImage(float2 fragCoord) : SV_Target {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Normalize coordinates (0.0 to 1.0)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 uv = fragCoord / iResolution.xy;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Adjust aspect ratio so circles are circular"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 centeredUv = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;"
