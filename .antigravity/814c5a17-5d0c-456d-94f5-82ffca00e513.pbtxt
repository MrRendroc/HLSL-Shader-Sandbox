        }
        lines {
          text: "    code: `/*"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Raymarched Metallic Sphere"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Illustrates 3D rendering in a single fragment shader using Signed Distance Fields (SDF)."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " */"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Signed Distance Field (SDF) of a sphere"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float sdSphere(float3 p, float r) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return length(p) - r;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// SDF of an infinite floor plane"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float sdPlane(float3 p, float h) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return p.y - h;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Scene SDF combining all elements"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float map(float3 p, out int matId) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float d1 = sdSphere(p - float3(0.0, sin(iTime * 1.5) * 0.4 + 0.4, 0.0), 0.7);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float d2 = sdPlane(p, -0.3);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (d1 < d2) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
