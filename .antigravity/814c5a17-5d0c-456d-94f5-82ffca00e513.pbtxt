        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 4. Translate Object-Oriented texture sampling"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // iChannel0.Sample(g_sampler, uv) -> texture(iChannel0, uv)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  code = code.replace(/\\b([A-Za-z0-9_]+)\\.Sample\\s*\\(\\s*[A-Za-z0-9_]+\\s*,\\s*([^)]+)\\)/g, \'texture($1, $2)\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // iChannel0.SampleLevel(g_sampler, uv, lod) -> textureLod(iChannel0, uv, lod)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  code = code.replace(/\\b([A-Za-z0-9_]+)\\.SampleLevel\\s*\\(\\s*[A-Za-z0-9_]+\\s*,\\s*([^,]+)\\s*,\\s*([^)]+)\\)/g, \'textureLod($1, $2, $3)\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 5. Detect and rename user-defined \"main\" to \"userMain\" to prevent conflict with WebGL main()"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let hasUserMain = false;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let hasMainImageOut = false;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let hasMainImageReturn = false;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Let\'s analyze what entry point functions are defined"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (/\\bvoid\\s+mainImage\\s*\\(\\s*(out\\s+)?vec4\\s+\\w+\\s*,\\s*(in\\s+)?vec2\\s+\\w+\\s*\\)/.test(code)) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hasMainImageOut = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  } else if (/\\bvec4\\s+mainImage\\s*\\(\\s*vec2\\s+\\w+\\s*\\)/.test(code)) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hasMainImageReturn = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  } else if (/\\bvec4\\s+main\\s*\\(\\s*vec2\\s+\\w+\\s*\\)/.test(code)) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Rename vec4 main(vec2 fragCoord) -> vec4 userMain(vec2 fragCoord)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code = code.replace(/\\b(vec4\\s+)main\\s*\\(\\s*(vec2\\s+\\w+\\s*)\\)/g, \'$1userMain($2)\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hasUserMain = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  } else if (/\\bvec4\\s+main\\s*\\(\\s*\\)/.test(code)) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Rename vec4 main() -> vec4 userMain()"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code = code.replace(/\\b(vec4\\s+)main\\s*\\(\\s*\\)/g, \'$1userMain()\');"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hasUserMain = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
