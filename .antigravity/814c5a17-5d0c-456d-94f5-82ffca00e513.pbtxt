        }
        lines {
          text: "  for (const [regex, replacement] of typeReplacements) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code = code.replace(regex, replacement);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
