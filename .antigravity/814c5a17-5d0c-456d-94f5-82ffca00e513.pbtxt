          text: "    [/\\bbool4\\b/g, \'bvec4\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    [/\\bfloat2x2\\b/g, \'mat2\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    [/\\bfloat3x3\\b/g, \'mat3\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    [/\\bfloat4x4\\b/g, \'mat4\'],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
