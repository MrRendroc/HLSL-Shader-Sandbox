        }
        lines {
          text: "        float theta = (iMouse.x / iResolution.x - 0.5) * 6.28;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3x3 rotY = float3x3("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            cos(theta), 0.0, sin(theta),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            0.0,        1.0, 0.0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            -sin(theta),0.0, cos(theta)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ro = mul(rotY, ro);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        rd = mul(rotY, rd);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Ray marching loop"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float t = 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    int matId = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    int hitMat = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bool hit = false;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 p = float3(0, 0, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (int i = 0; i < 80; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p = ro + rd * t;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float d = map(p, matId);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (d < 0.001) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            hit = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            hitMat = matId;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        t += d;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (t > 15.0) break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 col = float3(0.05, 0.07, 0.12); // Background color"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (hit) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 norm = getNormal(p);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 lightDir = normalize(float3(1.5, 3.0, -1.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Base materials"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 baseCol = float3(0.0, 0.0, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float roughness = 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (hitMat == 1) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            // Shiny Metallic Red/Orange Sphere"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            baseCol = float3(0.9, 0.25, 0.1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            roughness = 0.1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        } else if (hitMat == 2) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            // Infinite Checkerboard floor"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            float checkSize = 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            float f = frac(floor(p.x * checkSize) * 0.5 + floor(p.z * checkSize) * 0.5);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            baseCol = f > 0.0 ? float3(0.2, 0.25, 0.3) : float3(0.5, 0.55, 0.6);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            roughness = 0.9;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Lighting model (Lambertian + Phong specular)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float diff = saturate(dot(norm, lightDir));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 viewDir = normalize(ro - p);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 halfDir = normalize(lightDir + viewDir);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float spec = pow(saturate(dot(norm, halfDir)), roughness == 0.1 ? 64.0 : 16.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Shadowing"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float shadow = getShadow(p + norm * 0.01, lightDir);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Ambient Occlusion approximation (simply based on floor distance/height)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float ao = hitMat == 2 ? saturate(0.5 + 0.5 * p.y) : 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 ambient = float3(0.06, 0.08, 0.14) * ao;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col = ambient + baseCol * diff * shadow + float3(1.0, 0.95, 0.8) * spec * (roughness == 0.1 ? 0.8 : 0.1) * shadow;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Fog based on distance"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col = lerp(col, float3(0.05, 0.07, 0.12), saturate(t / 15.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Gamma correction"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    col = pow(col, float3(0.4545, 0.4545, 0.4545));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return float4(col, 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}`"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'mandelbrot\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Interactive Mandelbrot\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A smooth infinite zoom Mandelbrot fractal with customizable speed and color banding.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    difficulty: \'intermediate\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'fractal\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code: `/*"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Interactive Mandelbrot Set"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Uses coordinate interpolation and smooth color iteration math."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Click and drag on screen to explore different areas!"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " */"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float4 mainImage(float2 fragCoord) : SV_Target {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Normalize coordinates"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 uv = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Zoom and pan logic"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float zoom = pow(2.0, -1.0 - sin(iTime * 0.2) * 5.0); // Automatical zoom-in-out wave"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 center = float2(-0.743643887037158704752191506114774, 0.131825904205311970493132056385139);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // If mouse clicks/drags, center on the mouse target"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (iMouse.z > 0.0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float2 mouseUv = (iMouse.xy - 0.5 * iResolution.xy) / iResolution.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        center = mouseUv * 2.0 - float2(0.5, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        zoom = 0.05; // Lock zoom when exploring with mouse"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Set complex coordinate c = x + i*y"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 c = uv * zoom * 4.0 + center;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 z = float2(0.0, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float iter = 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const float maxIter = 150.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Mandelbrot escape-time formula: z_{n+1} = z_n^2 + c"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (float i = 0.0; i < maxIter; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (dot(z, z) > 4.0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            iter = i;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // z^2 = (x^2 - y^2) + i * (2*x*y)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        z = float2(z.x * z.x - z.y * z.y, 2.0 * z.x * z.y) + c;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 col = float3(0.0, 0.0, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (iter < maxIter) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Smooth coloring algorithm to prevent banding artifacts"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float log_zn = log(dot(z, z)) / 2.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float nu = log(log_zn / log(2.0)) / log(2.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float smoothIter = iter + 1.0 - nu;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Map iter to complex color palettes"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float factor = smoothIter / 30.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col = 0.5 + 0.5 * cos(factor + float3(0.0, 0.6, 1.2));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Highlight borders with a metallic shimmer"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col *= sin(factor * 10.0) * 0.3 + 0.7;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return float4(col, 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}`"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'retro-wave\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'80s Outrun Synthwave\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A nostalgic neon cyberwave grid with mountains and a glowing vector sun.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    difficulty: \'advanced\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'patterns\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code: `/*"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * 80s Outrun Synthwave Grid"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Rendered using dynamic line calculations, perspective mapping, and neon glows."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " */"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Helper to calculate a glowing neon line"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float lineGlow(float d, float thickness, float glow) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return thickness / (d + glow);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Simple pseudo-random hash"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float hash(float n) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return frac(sin(n) * 43758.5453123);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// 1D noise for mountain generation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float noise(float x) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float i = floor(x);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float f = frac(x);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    f = f * f * (3.0 - 2.0 * f);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return lerp(hash(i), hash(i + 1.0), f);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float4 mainImage(float2 fragCoord) : SV_Target {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 uv = fragCoord / iResolution.xy;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 centered = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 col = float3(0.01, 0.0, 0.02); // Deep dark purple background"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // 1. Starfield / Cyber Nebula glow"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float stars = saturate(sin(hash(floor(centered.x * 120.0) + floor(centered.y * 120.0) * 91.0) * 8.0) - 0.98);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    stars *= step(centered.y, 0.05); // Only above horizon"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    col += float3(stars, stars, stars) * 0.8;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Purple horizon glow"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float horizonGlow = exp(-abs(centered.y - 0.05) * 8.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    col += float3(0.7, 0.0, 0.8) * horizonGlow * 0.4;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // 2. Neon Sun rendering"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 sunPos = float2(0.0, 0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float distToSun = length(centered - sunPos);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (distToSun < 0.28) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Glowing orange-to-yellow gradient"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 sunCol = lerp(float3(1.0, 0.0, 0.4), float3(1.0, 0.9, 0.1), (centered.y - sunPos.y + 0.28) / 0.56);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Outrun sun horizontal slicing bars"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float barFreq = 22.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float barWidth = 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float slice = step(0.12, frac((centered.y - iTime * 0.03) * barFreq));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Progressively thicken bars near the bottom of the sun"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float bottomFactor = saturate((sunPos.y - centered.y) / 0.28);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        slice = lerp(1.0, slice, bottomFactor);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col = lerp(col, sunCol, slice);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Sun outer glow"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float sunGlow = exp(-distToSun * 4.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    col += float3(1.0, 0.3, 0.0) * sunGlow * 0.15;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // 3. Grid perspective floor rendering"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (centered.y < 0.03) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Coordinate transformation for 3D grid perspective"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 p = float3(centered.x, centered.y - 0.03, 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 rd = normalize(p);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Map 2D point to infinite plane coordinates"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float planeZ = -0.3 / rd.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float2 planePos = rd.xz * planeZ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Scroll grid into the screen over time"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        planePos.y += iTime * 0.8;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Grid lines (vertical and horizontal)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float gridLineWidth = 0.025;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float gridCellWidth = 0.2;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float vLine = abs(frac(planePos.x / gridCellWidth + 0.5) - 0.5) / (gridLineWidth * planeZ);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float hLine = abs(frac(planePos.y / gridCellWidth + 0.5) - 0.5) / (gridLineWidth * planeZ);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float gridLines = saturate(lineGlow(vLine, 0.08, 0.15) + lineGlow(hLine, 0.08, 0.15));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Fade grid into the distance"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float fade = saturate(exp((centered.y - 0.03) * 6.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Cyber-pink grid line coloring"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 gridCol = float3(0.0, 0.9, 1.0); // Cyan base"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        gridCol = lerp(gridCol, float3(1.0, 0.0, 0.6), sin(planePos.y * 0.2) * 0.5 + 0.5); // Morph to neon pink"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col += gridCol * gridLines * fade;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // 4. Distant Cyber Mountains"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float mountainVal = noise(centered.x * 5.0) * 0.12 + noise(centered.x * 15.0) * 0.03 + 0.01;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (centered.y < mountainVal && centered.y >= 0.03) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3 mountainCol = float3(0.05, 0.0, 0.1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Highlight mountain crest with cyan glow"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float crest = exp(-abs(centered.y - mountainVal) * 50.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        col = lerp(col, mountainCol + float3(0.0, 0.8, 1.0) * crest * 0.5, 0.85);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Add CRT screen curvature vignette"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 vignetteUv = uv * (1.0 - uv.yx);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float vig = vignetteUv.x * vignetteUv.y * 15.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    col *= pow(vig, 0.25);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return float4(col, 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}`"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'liquid-metal\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Liquid Plasma Metal\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'A chrome-like metallic liquid simulation using multiple octaves of sine wave warping.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    difficulty: \'advanced\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'patterns\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code: `/*"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Liquid Plasma Metal"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * A highly reflective chrome effect achieved through fractal noise warping and normal calculation."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " */"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Generate complex wave pattern"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float wavePattern(float3 p) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    p.xy += sin(p.z + p.xy * 2.0 + iTime) * 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Stack multiple octaves of sine functions"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float amp = 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float sum = 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (int i = 0; i < 5; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p = float3("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            p.y + p.z + sin(p.x + iTime * 0.3),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            p.z - p.x + cos(p.y - iTime * 0.2),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            p.x + p.y + sin(p.z * 1.5 + iTime)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        sum += abs(sin(p.x + p.y + p.z)) * amp;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        p *= 1.8;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        amp *= 0.55;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return sum;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float4 mainImage(float2 fragCoord) : SV_Target {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 uv = fragCoord / iResolution.xy;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 centered = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Scale coordinates"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 p = float3(centered * 1.8, iTime * 0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Find height values for normal vector approximation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float eps = 0.025;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float h = wavePattern(p);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float hX = wavePattern(p + float3(eps, 0.0, 0.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float hY = wavePattern(p + float3(0.0, eps, 0.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Approximate surface normals (derivative-based)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 normal = normalize(float3((h - hX) / eps, (h - hY) / eps, 0.8));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Lighting vectors"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 lightDir = normalize(float3(sin(iTime), cos(iTime * 0.5), 1.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 viewDir = float3(0.0, 0.0, 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Diffuse + High Specular Chrome lighting"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float diff = dot(normal, lightDir) * 0.5 + 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 ref = reflect(-lightDir, normal);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float spec = pow(saturate(dot(ref, viewDir)), 16.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Base chrome metallic color palette"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 baseCol = 0.5 + 0.5 * cos(h * 3.0 + float3(0.0, 1.5, 3.0) + iTime * 0.2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    baseCol = lerp(float3(0.85, 0.9, 0.95), baseCol, 0.4); // Bring in subtle silver reflections"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Final chrome shading"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 finalCol = baseCol * diff + float3(1.0, 1.0, 1.0) * spec * 0.9;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Deepen crevices (Ambient Occlusion approximation)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    finalCol *= saturate(h * 1.5);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Add dynamic glowing ring highlights"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float ring = saturate(1.0 - abs(h - 0.7) * 4.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    finalCol += float3(0.0, 0.7, 1.0) * pow(ring, 3.0) * 0.25;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return float4(finalCol, 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}`"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'underwater-caustics\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Sunlit Water Caustics\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Procedural underwater lighting caustics overlay with subtle particle details.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    difficulty: \'intermediate\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'procedural\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    code: `/*"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Sunlit Water Caustics"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * A mathematically simulated underwater caustics pattern."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " */"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "float4 mainImage(float2 fragCoord) : SV_Target {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 uv = fragCoord / iResolution.xy;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 p = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Warp coordinates to simulate light refraction through ripples"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float2 uvWarped = p * 4.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float time = iTime * 0.8;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Accumulate multiple overlapping wave directions"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float causticsVal = 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (int i = 0; i < 4; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        // Overlapping polar waves"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        uvWarped += float2("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            sin(uvWarped.y + time + float(i)),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            cos(uvWarped.x - time + float(i))"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        causticsVal += 1.0 / length(float2("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            sin(uvWarped.x + time),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            cos(uvWarped.y + time)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        ));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    causticsVal /= 4.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    causticsVal = saturate(pow(causticsVal, 2.5) * 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Dynamic water depth color gradient"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float3 waterCol = lerp("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3(0.02, 0.2, 0.45), // Shallow vibrant blue"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        float3(0.01, 0.05, 0.18), // Deep abyssal navy"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        uv.y"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Golden sun shafts from top of the screen"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float sunShaft = saturate(1.0 - abs(p.x - 0.2) * 0.5) * saturate(1.0 - uv.y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    waterCol += float3(0.9, 0.85, 0.5) * sunShaft * 0.3;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Apply caustics lighting"
